# Execution safety
CONSORS_MODE=read-only
CONSORS_TARGET_ENV=sandbox

# Target URLs
CONSORS_PROD_BASE_URL=https://api.consorsbank.de/trading
CONSORS_SANDBOX_BASE_URL=https://api.consorsbank.de/sandbox/trading

# Optional legacy override for the active target URL
# CONSORS_BASE_URL=https://api.consorsbank.de/sandbox/trading

# Optional legacy compatibility flag
# CONSORS_SANDBOX=true

# OAuth application settings
CONSORS_CLIENT_ID=your-client-id
CONSORS_CLIENT_SECRET=your-client-secret
CONSORS_REDIRECT_URI=http://localhost:8787/callback

# Access token sources: configure exactly one
# CONSORS_ACCESS_TOKEN=
# CONSORS_ACCESS_TOKEN_FILE=/absolute/path/to/consorsbank.token
# CONSORS_ACCESS_TOKEN_COMMAND=security find-generic-password -a "$USER" -s consorsbank-sandbox-token -w

# Optional refresh token
CONSORS_REFRESH_TOKEN=

# Request and polling behavior
CONSORS_REQUEST_TIMEOUT_SECONDS=30
CONSORS_POLL_INTERVAL_MILLIS=1500
CONSORS_MAX_POLL_ATTEMPTS=10
